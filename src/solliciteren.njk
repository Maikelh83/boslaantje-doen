<body>

<a href="#main" class="skip-link">Direct naar de inhoud</a>

{% include "shared-header.njk" %}

<section class="hero">
<div class="wrap">
<span class="eyebrow" style="color:#fff">Werken bij Boslaantje Doen · Veenendaal</span>
<h1>Kom het team versterken.</h1>
<p>Wij zoeken gezellige aanpakkers voor de snackbar en bezorging in Veenendaal. Bekijk de vacatures, vul je gegevens in en verstuur je sollicitatie — we reageren snel.</p>
<div class="steps">
<span class="step"><b>1</b> Kies een functie</span>
<span class="step"><b>2</b> Vul je gegevens in</span>
<span class="step"><b>3</b> Verstuur je sollicitatie</span>
</div>
</div>
</section>

<aside class="trust" aria-label="Waarom werken bij Boslaantje Doen">
<div class="wrap">
<ul>
<li>
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3l2.4 4.9 5.4.8-3.9 3.8.9 5.4L12 16.6 7.2 18.7l.9-5.4L4.2 8.7l5.4-.8z"/></svg>
<div><b>20+ jaar ervaring</b><span>Een vertrouwd gezicht in Veenendaal</span></div>
</li>
<li>
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 8v4l3 2M21 12a9 9 0 1 1-9-9"/></svg>
<div><b>Flexibele uren</b><span>Past bij school, studie of gezin</span></div>
</li>
<li>
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M17 20h5v-2a4 4 0 0 0-3-3.87M9 20H4v-2a4 4 0 0 1 3-3.87m5-4a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm6 0a4 4 0 1 0-1.13-7.84"/></svg>
<div><b>Gezellig team</b><span>Samen aanpakken, samen lachen</span></div>
</li>
<li>
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
<div><b>Snel antwoord</b><span>Reactie binnen 1 werkdag</span></div>
</li>
</ul>
</div>
</aside>

<main id="main">
<div class="wrap" style="max-width:820px">

<section class="cat">
<span class="eyebrow">Vacatures</span>
<h2>Waar we naar op zoek zijn</h2>
<p class="sub">Twee functies op dit moment — sta je functie er niet bij, informeer gerust ernaar.</p>
<div class="grid">
{%- for v in collections.vacatures %}
  {%- if v.data.actief %}
{{ vacatureCard(v.data) }}
  {%- endif %}
{%- endfor %}
</div>
</section>

<section id="apply-form" class="cat">
<span class="eyebrow">Solliciteren</span>
<h2>Vertel ons over jezelf</h2>
<p class="sub">Vul het formulier in — we nemen snel contact met je op.</p>

<div class="cart" style="position:static;max-width:520px">
<div class="cart-body">
<div class="cart-fields">
<div><label for="functie">Functie</label>
<select id="functie">
{%- for v in collections.vacatures %}
  {%- if v.data.actief %}
<option value="{{ v.data.functie }}">{{ v.data.functie }}</option>
  {%- endif %}
{%- endfor %}
<option value="Anders">Anders / weet ik nog niet</option>
</select></div>
<div><label for="naam">Naam</label>
<input type="text" id="naam" placeholder="Je naam"></div>
<div><label for="contact">Telefoon of e-mail</label>
<input type="text" id="contact" placeholder="Zodat we je kunnen bereiken"></div>
<div><label for="beschikbaarheid">Beschikbaarheid</label>
<input type="text" id="beschikbaarheid" placeholder="Bijv. avonden en weekend"></div>
<div><label for="motivatie">Motivatie (optioneel)</label>
<textarea id="motivatie" rows="4" placeholder="Vertel kort iets over jezelf"></textarea></div>
</div>
<div class="cart-actions">
<button class="btn btn-green" id="sendMail" type="button">Verstuur sollicitatie</button>
<a class="wa-alt" id="sendWa" href="#" target="_blank" rel="noopener">Liever appen? Verstuur je sollicitatie via WhatsApp →</a>
</div>
<p id="formStatus" class="form-status" role="status" aria-live="polite"></p>
</div>
</div>
</section>

</div>
</main>

{% include "shared-footer.njk" %}

<script>
(function(){
var FORMSPREE_ENDPOINT = 'https://formspree.io/f/mvzepvgz';
var WHATSAPP_NUMMER = '31318514916';

function g(id){ return document.getElementById(id); }

function buildMessage(){
return 'Sollicitatie via de website\n' +
'Functie: ' + g('functie').value + '\n' +
'Naam: ' + g('naam').value + '\n' +
'Contact: ' + g('contact').value + '\n' +
'Beschikbaarheid: ' + g('beschikbaarheid').value + '\n' +
'Motivatie: ' + g('motivatie').value;
}

function valid(){
return g('naam').value.trim() !== '' && g('contact').value.trim() !== '';
}

var wf = document.getElementById('waFloat');
if(wf){ wf.href = 'https://wa.me/' + WHATSAPP_NUMMER + '?text=' + encodeURIComponent('Hoi! Ik heb een vraag over werken bij Boslaantje Doen.'); }

var sendWaBtn = g('sendWa');
if(sendWaBtn){
sendWaBtn.addEventListener('click', function(e){
if(!valid()){
e.preventDefault();
var status = g('formStatus');
if(status){ status.textContent = 'Vul in ieder geval je naam en contactgegevens in.'; }
return;
}
this.href = 'https://wa.me/' + WHATSAPP_NUMMER + '?text=' + encodeURIComponent(buildMessage());
});
}

var sendMailBtn = g('sendMail');
if(sendMailBtn){
sendMailBtn.addEventListener('click', function(){
var status = g('formStatus');
if(!valid()){
if(status){ status.textContent = 'Vul in ieder geval je naam en contactgegevens in.'; }
return;
}
if(status){ status.textContent = 'Bezig met versturen...'; }
fetch(FORMSPREE_ENDPOINT, {
method: 'POST',
headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
body: JSON.stringify({
_subject: 'Nieuwe sollicitatie via de website',
functie: g('functie').value,
naam: g('naam').value,
contact: g('contact').value,
beschikbaarheid: g('beschikbaarheid').value,
motivatie: g('motivatie').value,
sollicitatie: buildMessage()
})
}).then(function(r){
if(r.ok){
if(status){ status.textContent = 'Bedankt! Je sollicitatie is verstuurd.'; }
} else {
if(status){ status.textContent = 'Er ging iets mis. Probeer het via WhatsApp.'; }
}
}).catch(function(){
if(status){ status.textContent = 'Er ging iets mis. Probeer het via WhatsApp.'; }
});
});
}
// let op: mobiel hamburgermenu wordt al geregeld door het script in shared-footer.njk
})();
</script>

</body>
</html>
