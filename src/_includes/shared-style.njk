<style>
@font-face {
font-family: 'TrashHand';
src: url('data:font/woff2;base64,') format('woff2');
font-weight: normal;
font-style: normal;
font-display: swap;
}

:root{
--green:#4A5D3D;--green-deep:#3E4E34;--green-ink:#37472E;
--ink:#000;--paper:#fff;--paper-2:#F5F3EF;--paper-line:#E6E2DA;
--tofill-line:#d8d3c8;
--tofill-bg:#f5f3ef;
--font-display:'TrashHand','Segoe Print','Bradley Hand',cursive;
--font-body:'Open Sans',system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
--wrap:1140px;--r:16px;--shadow:0 14px 34px -20px rgba(30,40,20,.4);
--logo:url('data:image/png;base64,');
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);color:var(--ink);background:var(--paper);line-height:1.62;font-size:16.5px;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
.skip-link{position:absolute;left:-9999px;top:0;z-index:100;background:var(--green);color:#fff;padding:.7em 1.2em;border-radius:0 0 10px 0;font-weight:800}
.skip-link:focus{left:0}
.wrap{max-width:var(--wrap);margin:0 auto;padding:0 22px}
h1,h2,h3.d{font-family:var(--font-display);font-weight:400;line-height:1.12;color:var(--green-ink);letter-spacing:.01em}
h2{font-size:clamp(1.9rem,5vw,2.9rem)}
.eyebrow{font-weight:800;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--green);display:inline-flex;align-items:center;gap:.55em}
.eyebrow::before{content:"";width:24px;height:2px;background:var(--green);display:inline-block}
.hero .eyebrow::before{background:#fff}

.btn{display:inline-flex;align-items:center;gap:.5em;font-weight:800;font-size:1rem;padding:.85em 1.5em;border-radius:999px;border:2px solid transparent;cursor:pointer;transition:transform .15s,background .15s,color .15s;line-height:1;font-family:var(--font-body)}
.btn:focus-visible{outline:3px solid var(--green);outline-offset:3px}
.btn-green{background:var(--green);color:#fff;box-shadow:0 10px 24px -10px rgba(74,93,61,.75)}
.btn-green:hover{background:var(--green-deep);transform:translateY(-3px);box-shadow:0 14px 28px -10px rgba(74,93,61,.8)}
.btn-outline{background:transparent;color:var(--green-ink);border-color:var(--green)}
.btn-outline:hover{background:var(--green);color:#fff}
.btn-ghost{background:#fff;color:var(--green-ink);border:1.5px solid var(--paper-line)}
.btn-ghost:hover{border-color:var(--green)}

header{position:sticky;top:0;z-index:40;background:var(--paper);border-bottom:1px solid var(--paper-line);box-shadow:0 4px 14px -11px rgba(30,40,20,.35)}
.nav{display:flex;align-items:center;justify-content:space-between;height:66px;gap:1rem}
.brand{display:flex;align-items:center;gap:.6rem}
.brand .logo{width:132px;height:42px;background:var(--logo) left center/contain no-repeat}
.nav-links{display:none;align-items:center;gap:1.35rem}
.nav-links a{font-weight:600;letter-spacing:.01em;font-size:1rem;color:var(--green-ink);white-space:nowrap}
.nav-links a:hover{color:var(--green)}
.nav-links a[aria-current="page"]{color:var(--green);border-bottom:2px solid var(--green)}
.nav .btn-green.nav-order{padding:.6em 1.1em;font-size:.92rem}

.nav-toggle{
display:inline-flex;flex-direction:column;justify-content:center;gap:5px;
width:44px;height:44px;padding:0 10px;background:none;border:none;cursor:pointer;margin-left:.4rem;
}
.nav-toggle span{display:block;height:2.5px;width:100%;background:var(--green-ink);border-radius:2px;
transition:transform .25s ease,opacity .2s ease}
.nav-toggle[aria-expanded="true"] span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}
.nav-toggle[aria-expanded="true"] span:nth-child(2){opacity:0}
.nav-toggle[aria-expanded="true"] span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}

.mobile-menu{
display:flex;flex-direction:column;gap:.2rem;
background:var(--paper-2);border-top:1px solid var(--paper-line);
padding:0 22px;max-height:0;overflow:hidden;opacity:0;
transition:max-height .32s ease,opacity .22s ease,padding .32s ease;
}
.mobile-menu.is-open{max-height:520px;opacity:1;padding:.6rem 22px 1.1rem}
.mobile-menu[hidden]{display:none}
.mobile-menu a{color:var(--green-ink);font-weight:600;font-size:1.05rem;padding:.85rem .2rem;
border-bottom:1px solid var(--paper-line)}
.mobile-menu a:last-of-type{border-bottom:none}
.mobile-menu .mobile-order{margin-top:.8rem;justify-content:center;border-bottom:none}

@media(min-width:1120px){
.nav-links{display:flex}
.nav-toggle{display:none}
.mobile-menu{display:none !important}
}
@media (prefers-reduced-motion:reduce){.nav-toggle span{transition:none}}

.hero{background:linear-gradient(105deg,var(--green-deep) 0%,var(--green) 65%,var(--green) 100%);color:#fff;padding:clamp(2.4rem,6vw,4rem) 0}
.hero h1{color:#fff;font-size:clamp(2.1rem,5.5vw,3.4rem);margin-bottom:.7rem;max-width:18ch}
.hero p{font-size:clamp(1.05rem,2.2vw,1.22rem);max-width:52ch;color:rgba(255,255,255,.9)}
.hero .steps{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1.6rem}
.hero .step{background:rgba(255,255,255,.14);border-radius:999px;padding:.45rem 1rem;font-weight:700;font-size:.85rem;display:inline-flex;align-items:center;gap:.5em}
.hero .step b{background:#fff;color:var(--green);width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:.8rem}

.trust{border-bottom:1px solid var(--paper-line);background:#fff}
.trust ul{list-style:none;display:grid;grid-template-columns:repeat(2,1fr);gap:.9rem 1.4rem;padding:1.1rem 0}
@media(min-width:760px){.trust ul{grid-template-columns:repeat(4,1fr)}}
.trust li{display:flex;align-items:flex-start;gap:.6rem;font-size:.9rem;line-height:1.35}
.trust svg{width:22px;height:22px;flex:none;color:var(--green);margin-top:.05rem}
.trust b{display:block;font-weight:800;color:var(--green-ink);font-size:.92rem}
.trust span{color:#5a5a52}

main{padding:clamp(2.6rem,6vw,4rem) 0 5rem}
.layout{display:grid;gap:2rem;align-items:start}
@media(min-width:960px){.layout{grid-template-columns:1fr 340px}}

.cat{margin-bottom:2.4rem}
.cat h2{margin-bottom:.3rem}
.cat .sub{color:#5a5a52;margin-bottom:1.3rem;font-size:1rem}
.grid{display:grid;gap:1.2rem}
@media(min-width:600px){.grid{grid-template-columns:1fr 1fr}}
.pkg{background:#fff;border:1px solid var(--paper-line);border-radius:var(--r);overflow:hidden;display:flex;flex-direction:column;box-shadow:var(--shadow);transition:transform .18s,box-shadow .18s}
.pkg:hover{transform:translateY(-4px);box-shadow:0 22px 40px -22px rgba(30,40,20,.5)}
.pkg .ph{aspect-ratio:3/2;background:var(--paper-2);display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--green);border-bottom:1px solid var(--paper-line);gap:.3rem;text-align:center;padding:.8rem}
.pkg .ph svg{width:36px;height:36px;opacity:.55}
.pkg .ph .cap{font-weight:800;font-size:.9rem;color:var(--green-ink)}
.pkg .ph .hint{font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;font-weight:800;color:#9aa08f}
.pkg-body{padding:1.2rem 1.3rem 1.3rem;display:flex;flex-direction:column;flex:1}
.pkg-body h3{font-family:var(--font-display);font-size:1.35rem;color:var(--green-ink);margin-bottom:.35rem}
.pkg-body p{font-size:.94rem;color:#54544c;margin-bottom:1rem}
.pkg .price{display:flex;align-items:baseline;gap:.4rem;margin-bottom:1rem}
.pkg .amt{font-family:var(--font-display);font-size:1.5rem;color:var(--green)}
.pkg .unit{font-size:.8rem;color:#8a8a80;font-weight:700}
.pkg .add{margin-top:auto;align-self:flex-start}
.pkg .add.added{background:var(--green-deep);color:#fff;border-color:var(--green-deep)}
.tofill{border-style:dashed !important;border-color:var(--tofill-line) !important}
.tofill .ph{background:var(--tofill-bg)}
.tofill-tag{display:inline-block;font-size:.66rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--green);margin-bottom:.4rem}

.note-box{font-size:.9rem;color:#54544c;background:var(--paper-2);border-left:4px solid var(--green);padding:.9rem 1.1rem;border-radius:10px}
.note-biz{margin-top:.8rem;background:#fff;border:1px solid var(--paper-line);border-left:4px solid var(--green)}
.note-biz a{color:var(--green-ink);font-weight:800;text-decoration:underline;text-underline-offset:2px}
.note-biz a:hover{color:var(--green)}

.cart{position:sticky;top:82px;background:#fff;border:1px solid var(--paper-line);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden}
.cart-head{background:var(--green);color:#fff;padding:1rem 1.2rem;display:flex;align-items:center;gap:.6rem}
.cart-head svg{width:20px;height:20px}
.cart-head h3{font-family:var(--font-display);font-size:1.3rem;color:#fff}
.cart-head .count{margin-left:auto;background:#fff;color:var(--green);min-width:24px;height:24px;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;font-weight:800;font-size:.82rem;padding:0 .4rem}
.cart-body{padding:1.1rem 1.2rem 1.3rem}
.cart-empty{color:#8a8a80;font-size:.92rem;text-align:center;padding:1.2rem 0}
.cart-item{display:flex;align-items:center;gap:.6rem;padding:.55rem 0;border-bottom:1px solid var(--paper-line)}
.cart-item .nm{font-weight:700;font-size:.92rem;flex:1}
.cart-item .qty{display:flex;align-items:center;gap:.3rem}
.cart-item button.q{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--paper-line);background:#fff;cursor:pointer;font-weight:800;color:var(--green);line-height:1}
.cart-item button.q:hover{border-color:var(--green)}
.cart-item .n{min-width:20px;text-align:center;font-weight:800}
.cart-group-label{font-size:.68rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase;color:var(--green);margin:.8rem 0 .3rem}
.cart-group-label:first-child{margin-top:0}
.cart-item .nm em{font-style:normal;font-weight:600;font-size:.74rem;color:#9a9a90}
.cart-crosssell{font-size:.82rem;font-weight:600;color:var(--green-ink);background:var(--paper-2);border-radius:10px;padding:.65rem .8rem;margin-top:.9rem}
.cart-crosssell a{color:var(--green);font-weight:800;text-decoration:underline;text-underline-offset:2px;white-space:nowrap}
.cart-note a{color:var(--green-ink);text-decoration:underline;text-underline-offset:2px}
.cart-item .line-price{font-weight:800;font-size:.85rem;color:var(--green-ink);white-space:nowrap;margin-left:.5rem}
.cart-total{display:flex;justify-content:space-between;align-items:baseline;margin-top:.8rem;padding-top:.7rem;border-top:2px solid var(--paper-line);font-weight:800;font-size:.98rem;color:var(--green-ink)}
.cart-total .amt{font-family:var(--font-display);font-size:1.35rem;color:var(--green)}
.cart-total-note{font-size:.72rem;font-weight:600;color:#9a9a90;text-align:right;margin-top:.15rem}
.cart-fields{margin-top:1rem;display:flex;flex-direction:column;gap:.7rem}
.cart-fields label{font-weight:700;font-size:.82rem;display:block;margin-bottom:.2rem}
.cart-fields input,.cart-fields textarea{width:100%;font-family:var(--font-body);font-size:.95rem;padding:.6em .75em;border:1.5px solid var(--paper-line);border-radius:10px;background:var(--paper-2)}
.cart-fields input:focus,.cart-fields textarea:focus{outline:none;border-color:var(--green);background:#fff}
.cart-fields input.invalid,.cart-fields textarea.invalid{border-color:#b3261e;background:#fdf2f1}
.cart-actions{margin-top:1rem;display:flex;flex-direction:column;gap:.55rem}
.cart-actions .btn{width:100%;justify-content:center}
.wa-alt{display:block;text-align:center;font-weight:700;font-size:.88rem;color:var(--green-ink);text-decoration:underline;text-underline-offset:3px;padding:.2rem 0}
.wa-alt:hover{color:var(--green)}
.wa-alt:focus-visible{outline:3px solid var(--green);outline-offset:3px;border-radius:6px}
.cart-note{font-size:.76rem;color:#9a9a90;text-align:center;margin-top:.7rem}
.form-status{font-size:.86rem;text-align:center;margin-top:.6rem;font-weight:700;display:none}
.form-status.show{display:block}
.form-status.ok{color:var(--green-ink)}
.form-status.error{color:#b3261e}

.mobile-bar{position:fixed;left:0;right:0;bottom:0;z-index:50;background:#fff;border-top:1px solid var(--paper-line);padding:.7rem 1rem;display:none;align-items:center;gap:.8rem;box-shadow:0 -8px 24px -18px rgba(0,0,0,.4)}
.mobile-bar .sum{font-weight:800;font-size:.9rem}
.mobile-bar .btn{margin-left:auto}
@media(max-width:959px){
.cart{position:static}
.mobile-bar{display:flex}
main{padding-bottom:6rem}
}

.faq{padding:3.4rem 0;background:var(--paper-2);border-top:1px solid var(--paper-line)}
.faq .faq-head{margin-bottom:1.6rem;max-width:640px}
.faq .faq-head h2{margin-bottom:.4rem}
.faq .faq-head p{color:#5a5a52;font-size:.98rem}
.faq-list{display:flex;flex-direction:column;gap:.7rem;max-width:760px}
.faq-item{background:#fff;border:1px solid var(--paper-line);border-radius:var(--r);overflow:hidden}
.faq-item summary{cursor:pointer;list-style:none;padding:1rem 1.2rem;font-weight:800;color:var(--green-ink);display:flex;align-items:center;justify-content:space-between;gap:1rem}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:"+";font-size:1.3rem;color:var(--green);flex:none;transition:transform .2s;line-height:1}
.faq-item[open] summary::after{transform:rotate(45deg)}
.faq-item summary:hover{background:var(--paper-2)}
.faq-item .a{margin:0;padding:0 1.2rem 1.1rem;color:#54544c;font-size:.94rem;line-height:1.6}

footer{background:var(--green-ink);color:rgba(255,255,255,.75);padding:2.4rem 0;font-size:.9rem;text-align:center;margin-top:2rem}
footer a{color:#fff;text-decoration:underline;text-underline-offset:2px}

.wa-float{position:fixed;right:20px;bottom:20px;z-index:60;display:flex;align-items:center;gap:0;
text-decoration:none;transition:transform .18s}
.wa-float:hover{transform:translateY(-3px)}
.wa-float .bubble{background:#25D366;color:#fff;width:60px;height:60px;border-radius:50%;
display:flex;align-items:center;justify-content:center;box-shadow:0 10px 26px -8px rgba(0,0,0,.45)}
.wa-float .bubble svg{width:34px;height:34px}
.wa-float .lbl{background:#fff;color:#1a1a1a;font-weight:700;font-size:.9rem;padding:.6rem .9rem;
border-radius:999px;box-shadow:0 8px 22px -10px rgba(0,0,0,.4);margin-right:.6rem;
white-space:nowrap;opacity:0;transform:translateX(8px);pointer-events:none;transition:opacity .2s,transform .2s;
order:-1}
.wa-float:hover .lbl{opacity:1;transform:translateX(0)}
@media(max-width:959px){.wa-float{bottom:80px}}


  /* ---- footer (homepage-stijl, toegevoegd voor consistentie met index.html) ---- */
  footer{background:var(--ink);color:var(--paper);padding:3.2rem 0 2rem;position:relative;overflow:hidden}
  .foot-grid{display:grid;gap:2rem;margin-bottom:2.4rem}
  @media(min-width:760px){.foot-grid{grid-template-columns:1.4fr 1fr 1fr}}
  .foot-brand p{color:rgba(246,241,231,.72);max-width:34ch;font-size:.96rem}
  .foot-logo{width:170px;height:54px;background:var(--logo) left center/contain no-repeat;display:block;margin-bottom:.8rem;filter:invert(1)}
  .socials{display:flex;gap:.7rem;margin-top:1.2rem}
  .social{display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:50%;border:1.5px solid rgba(246,241,231,.4);color:var(--paper);transition:background .15s,color .15s,border-color .15s,transform .15s}
  .social svg{width:20px;height:20px}
  .social:hover{background:var(--paper);color:var(--ink);border-color:var(--paper);transform:translateY(-2px)}
  .foot-col h4{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--green);margin-bottom:.9rem;font-weight:900}
  .foot-col a{display:block;color:rgba(246,241,231,.82);padding:.28rem 0;font-weight:600;font-size:.96rem}
  .foot-col a:hover{color:#fff}
  .foot-bottom{border-top:1px solid rgba(246,241,231,.16);padding-top:1.5rem;display:flex;flex-wrap:wrap;gap:.6rem;justify-content:space-between;font-size:.85rem;color:rgba(246,241,231,.6)}.foot-order-alt{display:flex;align-items:center;justify-content:center;gap:.5rem;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(246,241,231,.16);font-size:.78rem;color:rgba(246,241,231,.55)}.foot-order-alt .tb-mark{display:inline-flex;color:rgba(246,241,231,.7)}.foot-order-alt .tb-mark svg{width:76px;height:auto;display:block}.foot-order-alt .tb-mark:hover{color:rgba(246,241,231,.95)}
</style>
